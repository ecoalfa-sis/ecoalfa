rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() && userProfile().data.active == true ? userProfile().data.role : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isMedico() {
      return role() == 'medico';
    }

    function isFullAccess() {
      return isAdmin() || isMedico();
    }

    function isOperador() {
      return role() == 'operador';
    }

    function isAsesor() {
      return role() == 'asesor';
    }

    function canReadIndicators() {
      return isFullAccess() || isOperador();
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isFullAccess());
      allow create, update, delete: if isFullAccess();
    }

    match /appointments/{appointmentId} {
      allow read: if isFullAccess() || isOperador();
      allow create, update: if isFullAccess() || isOperador();
      allow delete: if isFullAccess();
    }

    match /publicAppointmentRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isFullAccess() || isOperador();
    }

    match /doctors/{doctorId} {
      allow read: if isFullAccess() || isOperador();
      allow create, update, delete: if isFullAccess();
    }

    match /patients/{patientId} {
      allow read: if isFullAccess();
      allow create, update: if isFullAccess();
      allow delete: if isFullAccess();

      match /clinicalRecords/{recordId} {
        allow read: if isFullAccess();
        allow create, update: if isFullAccess();
        allow delete: if isFullAccess();
      }
    }

    match /inventory/{medicineId} {
      allow read: if isFullAccess() || isOperador();
      allow create, update: if isFullAccess() || isOperador();
      allow delete: if isFullAccess();

      match /movements/{movementId} {
        allow read: if isFullAccess() || isOperador();
        allow create: if isFullAccess() || isOperador();
        allow update, delete: if isFullAccess();
      }
    }

    match /invoices/{invoiceId} {
      allow read: if isFullAccess() || isOperador();
      allow create: if isFullAccess() || isOperador();
      allow update, delete: if isFullAccess();
    }

    match /indicators/{indicatorId} {
      allow read: if canReadIndicators();
      allow write: if isFullAccess();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
