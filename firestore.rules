rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() && userProfile().data.active == true ? userProfile().data.role : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isMedico() {
      return role() == 'medico';
    }

    function isOperador() {
      return role() == 'operador';
    }

    function isAsesor() {
      return role() == 'asesor';
    }

    function hasFullAccess() {
      return isAdmin() || isMedico();
    }

    function canReadIndicators() {
      return isAdmin() || isAsesor();
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || hasFullAccess()
        || (resource != null && resource.data.role == 'medico' && resource.data.active == true)
      );
      allow create, update, delete: if isAdmin();
    }

    match /publicAppointmentRequests/{requestId} {
      allow create: if signedIn();
      allow read, update, delete: if hasFullAccess() || isOperador();
    }

    match /doctors/{doctorId} {
      allow read: if signedIn();
      allow create, update, delete: if hasFullAccess();
    }

    match /appointments/{appointmentId} {
      allow read: if hasFullAccess() || isOperador() || (signedIn() && (resource == null || resource.data.authUid == request.auth.uid));
      allow create: if hasFullAccess() || isOperador() || signedIn();
      allow update: if hasFullAccess() || isOperador() || (signedIn() && resource.data.authUid == request.auth.uid);
      allow delete: if hasFullAccess();
    }

    match /appointmentSlots/{slotId} {
      allow read: if signedIn();
      allow create, update: if hasFullAccess() || isOperador() || (
        signedIn()
        && resource.data.status == 'available'
        && request.resource.data.status == 'booked'
        && request.resource.data.authUid == request.auth.uid
      );
      allow delete: if hasFullAccess();
    }

    match /patients/{patientId} {
      allow read: if signedIn();
      allow create: if hasFullAccess() || isOperador() || (signedIn() && request.resource.data.authUid == request.auth.uid);
      allow update: if hasFullAccess() || isOperador() || (signedIn() && (resource.data.authUid == request.auth.uid || !resource.data.authUid));
      allow delete: if hasFullAccess();

      match /clinicalRecords/{recordId} {
        allow read: if hasFullAccess() || (signedIn() && get(/databases/$(database)/documents/patients/$(patientId)).data.authUid == request.auth.uid);
        allow create, update: if hasFullAccess();
        allow delete: if hasFullAccess();
      }
    }

    match /inventory/{medicineId} {
      allow read: if isAdmin() || isMedico() || isOperador() || isAsesor();
      allow create, update: if isAdmin() || isMedico() || isOperador();
      allow delete: if isAdmin();

      match /movements/{movementId} {
        allow read: if isAdmin() || isMedico() || isOperador() || isAsesor();
        allow create: if isAdmin() || isMedico() || isOperador();
        allow update, delete: if isAdmin();
      }
    }

    match /invoices/{invoiceId} {
      allow read: if hasFullAccess() || isMedico() || isOperador() || (signedIn() && (resource == null || resource.data.authUid == request.auth.uid));
      allow create: if hasFullAccess() || isMedico() || isOperador() || signedIn();
      allow update, delete: if hasFullAccess();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin() || isMedico();
    }

    match /indicators/{indicatorId} {
      allow read: if canReadIndicators();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
